        <mxCell id="idxC9VfHnIsRoXNKkorq-57" parent="co_AC5JTf9_7fEwU2aVu-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Aufbau&lt;/font&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Auf beiden Feldseiten sind die Positionen 1, 3 und 5 besetzt&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ballwagen auf jede 1 (wenn 2 vorhanden)&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ablauf&lt;/font&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 27px; font-weight: normal;&quot;&gt;Bälle werden von A auf B gespielt. B nimmt an auf C. C fängt. A&lt;/font&gt;&lt;font style=&quot;font-size: 27px; font-weight: normal;&quot;&gt;&amp;nbsp;läuft nach B, B nach C und C mit Ball nach D.&amp;nbsp;&lt;/font&gt;&lt;/h1&gt;&lt;/li&gt;&lt;li&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 27px; font-weight: normal;&quot;&gt;D, E und F machen die Übung parallel.&lt;/font&gt;&lt;/h1&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Wartepositionen&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Position 1: beliebig viele möglich&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Position 5: eine Warteposition um Laufweg A-&amp;gt;B zu entschärfen.&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Varianten&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;A-&amp;gt;B: Ball wird geworfen, Ball wird aus dem Hinterfeld oder Vorderfeld geschlagen, Aufschlag&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;B und E: 2 Spielerinnen auf 5 und 4&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Angriffsaufbau nach Annahme/Abwehr&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Zusatzaufgaben&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Laufleitern in den Laufweg von 1-&amp;gt;5&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Laufleitern hinter Position 1&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;B/E starten an der Grundlinie oder an der Mittellinie&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Methodische Reihe&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Die Übung eignet sich gut zum Aufbau einer Methodischen Reihe zur Annahme, Angriffssicherung, Blocksicherung&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1440" width="960" x="1280" y="120" as="geometry" />
        </mxCell>
        <mxCell id="idxC9VfHnIsRoXNKkorq-58" edge="1" parent="co_AC5JTf9_7fEwU2aVu-1" style="curved=1;endArrow=classic;html=1;rounded=0;strokeWidth=5;dashed=1;dashPattern=8 8;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="490" />
              <mxPoint x="640" y="570" />
            </Array>
