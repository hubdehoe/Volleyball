        <mxCell id="2WzbCgfOdPQ7-o5riFMN-19" parent="2WzbCgfOdPQ7-o5riFMN-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Aufbau&lt;/font&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Alle Positionen in einem Halbfeld besetzt&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Zuspiel auf der 3&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ballwagen außerhalb des Feldes entweder neben der 1 oder der 5.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Bei mehr als 12 Spielerinnen Aufbau auf beiden Feldhälften möglich&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Gute Spieltagserwärmung kurz vor dem Einschlagen.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ablauf&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Trainer wirft den Ball von der Seitenlinie (1/5) ein&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Zuspiel spielt auf C (Variante Blau) oder D (Variante rot).&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;C/D Angriff ins Hinterfeld&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Hinterfeldspielerinnen verteidigen und Ball soll wieder zum Zuspiel&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Kontinuierliche Übung Zuspiel -&amp;gt; Angriff -&amp;gt; Abwehr&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Wenn der Ball ins Aus geht, wird neu angeworfen durch den Trainer&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Wartepositionen&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Hinter dem Feld. Wechsel kann zur Übungssteuerung genutzt werden.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Je nach Anzahl kann der Wechsel der Spielerin oder des gesamten Hinterfelds erfolgen&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Varianten&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Beginnen ohne Angriffe (nur gepritschte Bälle) aus dem Vorderfeld ins Hinterfeld.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ball wird ins Hinterfeld gelobbt&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Zusatzaufgabe&lt;/b&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&amp;nbsp;Zusatzaufgaben sind in dieser Übung eher kontraproduktiv&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Fokus&lt;/b&gt;&lt;/font&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&amp;nbsp;Bewegung auf die Abwehrposition (Variante blau oder rot) frühzeitig nach dem Zuspiel&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Direkt nach der Abwehraktion bewegung auf die Grundposition (schwarz)&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1440" width="960" x="1280" y="120" as="geometry" />
        </mxCell>
