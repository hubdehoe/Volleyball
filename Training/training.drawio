        <mxCell id="ib7h8lX3ivHrGwlihiNV-19" parent="ib7h8lX3ivHrGwlihiNV-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Aufbau&lt;/font&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Alle Positionen außer 6 in einem Halbfeld besetzt&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ballwagen hinten mittig&amp;nbsp;außerhalb des Feldes&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Bei mehr als 12 Spielerinnen Aufbau auf beiden Feldhälften möglich&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h1&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ablauf&lt;/font&gt;&lt;/h1&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;A spielt (Anwurf oder oberes Zuspiel) auf B. B oberes Zuspiel auf C. C greift auf D an. D wehrt wieder auf B ab. B oberes Zuspiel auf E. E greift auf A an und der Ablauf beginnt von vorn.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Jede Spielerin läuft ihrem Ball nach.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Wartepositionen&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Keine zusätzlichen Wartepositionen&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Varianten&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Beginnen ohne Angriffe (nur gepritschte Bälle) aus dem Vorderfeld ins Hinterfeld.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Ball wird ins Hinterfeld gelobbt&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;b&gt;Zusatzaufgaben&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;Laufleitern hinter die Gundlinie&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;br&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 27px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
